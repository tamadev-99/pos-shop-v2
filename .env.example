# --- Database (Supabase / Postgres) ---
DATABASE_URL="postgres://postgres:password@localhost:5432/pos_db"

# --- Authentication (Better-Auth) ---
# Rahasia acak untuk sesi (gunakan `openssl rand -base64 32`)
BETTER_AUTH_SECRET="your_secret_key"
# URL dasar aplikasi
BETTER_AUTH_URL="http://localhost:3000"

# --- Mayar Payment Gateway ---
# Dapatkan dari Dashboard Mayar > Developer > API Keys
MAYAR_API_KEY="your_mayar_api_key"
# Dapatkan saat Anda mengatur Webhook di Mayar
MAYAR_WEBHOOK_SECRET="your_webhook_secret"

# --- Deployment Note ---
# Pastikan untuk mengganti BETTER_AUTH_URL ke domain Vercel Anda di produksi.
# Contoh: NEXT_PUBLIC_URL="https://your-app.vercel.app"
